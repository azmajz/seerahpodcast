---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";

const features = [
	{
		title: "Deep Historical Context",
		description: "Detailed explanations of pre-Islamic Arabia and the socio-political climate surrounding the Prophet's ﷺ life.",
		icon: "🕌",
	},
	{
		title: "Engaging Storytelling",
		description: "Abdul Nasir Jangda brings the Seerah to life with an engaging and accessible narrative style.",
		icon: "🎙️",
	},
	{
		title: "Practical Lessons",
		description: "Extract practical wisdom and life lessons from the Prophet's ﷺ experiences to apply in our modern lives.",
		icon: "💡",
	},
	{
		title: "Comprehensive Journey",
		description: "An exhaustive 199-episode series covering everything from before his birth to his final days.",
		icon: "🗺️",
	},
    {
		title: "Authentic Sources",
		description: "Carefully researched and narrated based on the most authentic and traditional biographies of the Prophet ﷺ.",
		icon: "📚",
	},
    {
		title: "Spiritual Growth",
		description: "Deepen your love for the Messenger ﷺ and strengthen your Iman by learning about his unparalleled character.",
		icon: "🌱",
	},
];
---

<Layout>
	<Navbar />

	<main>
		<Hero />

		<section class="features">
			<div class="container">
				<div class="section-header">
					<h2>
						Why Listen to this <span class="gradient-text"
							>Seerah Series</span
						>?
					</h2>
					<p>
						We've combined traditional scholarship with modern
						storytelling.
					</p>
				</div>

				<div class="features-grid">
					{
						features.map((f) => (
							<div class="feature-card glass-card">
								<span class="feature-icon">{f.icon}</span>
								<h3>{f.title}</h3>
								<p>{f.description}</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="cta-section">
			<div class="container">
				<div class="cta-box glass-card">
					<h2>Embark on the Journey Today</h2>
					<p>
						Start listening to the most comprehensive Seerah series available in English. Follow the footsteps of the greatest man to ever live, episode by episode.
					</p>
					<div class="cta-buttons">
						<a href="/episodes/intro-pt-1" class="btn-primary">Start from Episode 1</a>
						<a href="/episodes" class="btn-primary">Browse All Episodes</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.features {
		padding: 6rem 0;
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-header h2 {
		font-size: clamp(2rem, 6vw, 2.5rem);
		margin-bottom: 1rem;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.feature-card {
		padding: 2.5rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
		backdrop-filter: blur(10px);
		border-radius: 16px;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.feature-card:hover {
		transform: translateY(-10px) scale(1.02);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
		border-color: rgba(var(--cerulean-rgb), 0.3);
	}

	.feature-icon {
		font-size: 2.5rem;
		display: block;
		margin-bottom: 1.5rem;
	}

	.feature-card h3 {
		margin-bottom: 1rem;
		font-size: 1.5rem;
	}

	.cta-section {
		padding: 6rem 0;
	}

	.cta-box {
		padding: 4rem;
		text-align: center;
		background: linear-gradient(
			135deg,
			var(--oxford-navy),
			var(--regal-navy)
		);
		color: white;
	}

	.cta-box h2 {
		color: white;
		font-size: clamp(2rem, 6vw, 2.5rem);
		margin-bottom: 1.5rem;
	}

	.cta-box p {
		font-size: 1.2rem;
		margin-bottom: 2.5rem;
		opacity: 0.9;
	}

	.cta-buttons {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.cta-buttons .btn-primary {
		background: white;
		color: var(--oxford-navy);
	}

	.cta-buttons .btn-primary:hover {
		background: var(--platinum);
	}
	@media (max-width: 768px) {
		.features,
		.cta-section {
			padding: 4rem 0;
		}
		.cta-box {
			padding: 3rem 1.5rem;
		}
		.cta-buttons .btn-primary {
			width: 100%;
		}
	}
</style>
