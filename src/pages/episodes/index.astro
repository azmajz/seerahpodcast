---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import EpisodeCard from "../../components/EpisodeCard.astro";
import ContinueListening from "../../components/ContinueListening.astro";
import { episodes } from "../../data/episodes";
import { PHASES, MILESTONES } from "../../data/phases";

const allEpisodes = episodes.map((ep) => ({
    ...ep,
    description: `${ep.title}. A comprehensive study of the Seerah by Shaykh Abdul Nasir Jangda.`,
    date: "Prophetic Biography",
    image: "/thumb.jpg",
}));

const groupedEpisodes = PHASES.map(phase => ({
    ...phase,
    episodes: allEpisodes.filter(ep => {
        const id = parseInt(ep.id);
        return id >= phase.startId && id <= phase.endId;
    })
})).filter(phase => phase.episodes.length > 0);

const makkanPhases = groupedEpisodes.filter(p => p.era === 'Makkan');
const madinanPhases = groupedEpisodes.filter(p => p.era === 'Madinan');
---

<Layout title="The Prophetic Path | Seerah of the Prophet ﷺ">
    <Navbar />

    <header class="page-header reveal-on-scroll">
        <div class="header-bg-glow"></div>
        <div class="container text-center">
            <div class="header-content mx-auto">
                <span class="badge">Prophetic Biography</span>
                <h1>
                    Journey Through the <br /><span class="text-accent">Life of the Messenger ﷺ</span>
                </h1>
                <p>
                    A definitive 199-episode archive detailing the character, struggle, and legacy 
                    of the Final Messenger ﷺ. Organized by chronological eras and thematic milestones.
                </p>
            </div>
        </div>
    </header>

    <main class="container">
        <ContinueListening />

        <!-- Browse Dashboard -->
        <div class="browse-dashboard reveal-on-scroll">
            <div class="dashboard-controls glass-card">
                <!-- Search & Quick Jump -->
                <div class="input-group">
                    <div class="search-box">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                        <input type="text" id="episodeSearch" placeholder="Search lessons, topics, or companions..." autocomplete="off" />
                    </div>
                    <div class="jump-box" title="Jump to Episode #">
                        <span class="jump-label">Ep</span>
                        <input type="number" id="quickJump" min="1" max="199" placeholder="--" />
                    </div>
                </div>

                <!-- Filters -->
                <div class="filter-actions">
                    <div class="era-switcher" id="eraSwitcher">
                        <button class="era-btn active" data-era="all">All Eras</button>
                        <button class="era-btn" data-era="Makkan">Makkan</button>
                        <button class="era-btn" data-era="Madinan">Madinan</button>
                    </div>
                    <button class="milestone-toggle" id="milestoneToggle">
                        <span class="star-icon">✦</span> Milestones
                    </button>
                </div>
            </div>

            <div class="dashboard-meta">
                ✨ <span id="currentFilterLabel">Full Journey</span> • <span id="resultCount">{allEpisodes.length}</span> Lessons
            </div>
        </div>

        <!-- Floating Phase Navigator (appears on scroll) -->
        <div class="floating-explorer" id="floatingExplorer">
            <div class="floating-content">
                <button class="floating-toggle" id="explorerToggle">
                    <span class="idx" id="activeIdx">01</span>
                    <span class="title" id="activeTitle">Before Revelation</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
                <div class="floating-progress-track">
                    <div class="floating-progress-fill" id="scrollProgress"></div>
                </div>
                
                <!-- Expanded Menu -->
                <div class="explorer-menu" id="explorerMenu">
                    <div class="menu-grid">
                        {groupedEpisodes.map((phase, idx) => (
                            <button class="menu-item" data-phase-id={phase.id} data-idx={idx + 1}>
                                <span class="m-idx">{(idx + 1).toString().padStart(2, '0')}</span>
                                <span class="m-title">{phase.title}</span>
                            </button>
                        ))}
                    </div>
                </div>
            </div>
        </div>

        <!-- Visual Phase Grid -->
        <div class="phase-grid-container reveal-on-scroll">
            <div class="grid-header">
                <h3>Select a Chapter</h3>
                <span class="scroll-hint">Scroll →</span>
            </div>
            <div class="phase-grid" id="phaseQuickNav">
                {groupedEpisodes.map((phase, idx) => (
                    <button class="phase-card" data-phase-id={phase.id} data-era={phase.era}>
                        <div class="phase-card-bg" style={`background: ${phase.color}`}></div>
                        <span class="phase-idx">{(idx + 1).toString().padStart(2, '0')}</span>
                        <h4>{phase.title}</h4>
                        <span class="phase-meta">{phase.episodes.length} ep</span>
                    </button>
                ))}
            </div>
        </div>

        <!-- Main Journey Stream -->
        <div id="episodesGrid" class="journey-stream">
            {
                groupedEpisodes.map((phase, phaseIdx) => (
                    <section id={phase.id} class="phase-section reveal-on-scroll" data-era={phase.era}>
                        <div class="phase-bg-number">{(phaseIdx + 1).toString().padStart(2, '0')}</div>
                        
                        <header class="phase-header">
                            <div class="phase-info">
                                <div class="era-indicator">{phase.era} Period</div>
                                <h2>{phase.title}</h2>
                                <p>{phase.description}</p>
                            </div>
                        </header>
                        
                        <div class="grid-layout">
                            {phase.episodes.map((episode, epIndex) => {
                                const isFeatured = MILESTONES.includes(Number(episode.id));
                                return (
                                    <div
                                        class={`episode-item reveal-on-scroll ${isFeatured ? 'featured' : ''}`}
                                        data-title={episode.title.toLowerCase()}
                                        data-id={episode.id}
                                        data-featured={isFeatured}
                                        style={`transition-delay: ${(epIndex % 6) * 50}ms`}
                                    >
                                        <EpisodeCard episode={episode} featured={isFeatured} />
                                    </div>
                                );
                            })}
                        </div>
                    </section>
                ))
            }
        </div>

        <!-- No Results -->
        <div id="noResults" class="no-results-container hidden">
            <div class="no-results-card glass-card">
                <h3>Beyond the Horizon</h3>
                <p>We couldn't find any matches for your current search or filters.</p>
                <button id="resetBrowsing" class="btn-primary">View Full Journey</button>
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<script>
    document.addEventListener('astro:page-load', () => {
        const searchInput = document.getElementById("episodeSearch") as HTMLInputElement;
        const quickJump = document.getElementById("quickJump") as HTMLInputElement;
        const phaseSections = document.querySelectorAll(".phase-section");
        const phaseCards = document.querySelectorAll(".phase-card");
        const eraBtns = document.querySelectorAll(".era-btn");
        const milestoneToggle = document.getElementById("milestoneToggle");
        const resultCount = document.getElementById("resultCount");
        const filterLabel = document.getElementById("currentFilterLabel");
        const noResults = document.getElementById("noResults");
        const resetBtn = document.getElementById("resetBrowsing");
        
        // Floating Nav Elements
        const floatingExplorer = document.getElementById('floatingExplorer');
        const explorerToggle = document.getElementById('explorerToggle');
        const explorerMenu = document.getElementById('explorerMenu');
        const scrollProgress = document.getElementById('scrollProgress');
        const activeIdx = document.getElementById('activeIdx');
        const activeTitle = document.getElementById('activeTitle');
        const menuItems = document.querySelectorAll('.menu-item');

        let activeEra = 'all';
        let showOnlyMilestones = false;

        // --- Core Filtering Logic ---
        function applyFilters() {
            const query = searchInput.value.trim().toLowerCase();
            let totalFound = 0;
            const phasesWithResults = new Set();

            phaseSections.forEach((section) => {
                const sect = section as HTMLElement;
                const era = sect.dataset.era;
                const items = section.querySelectorAll(".episode-item");
                let foundInSection = 0;

                const matchesEra = activeEra === 'all' || era === activeEra;

                items.forEach((item) => {
                    const el = item as HTMLElement;
                    const title = el.getAttribute("data-title") || "";
                    const id = el.getAttribute("data-id") || "";
                    const isFeatured = el.getAttribute("data-featured") === "true";

                    const matchesSearch = title.includes(query) || id.includes(query);
                    const matchesMilestone = !showOnlyMilestones || isFeatured;

                    if (matchesEra && matchesSearch && matchesMilestone) {
                        el.style.display = "block";
                        foundInSection++;
                        totalFound++;
                    } else {
                        el.style.display = "none";
                    }
                });

                sect.style.display = (foundInSection > 0) ? "block" : "none";
                if (foundInSection > 0) phasesWithResults.add(sect.id);
                
                if (query === "" && !showOnlyMilestones && matchesEra) {
                   sect.style.display = "block";
                }
            });

            // Update Nav Highlights
            phaseCards.forEach(card => {
                const el = card as HTMLElement;
                const matches = phasesWithResults.has(el.dataset.phaseId) || query === "";
                el.classList.toggle('has-results', matches && query !== "");
                
                const era = el.dataset.era;
                const matchesEra = activeEra === 'all' || era === activeEra;
                el.style.opacity = matchesEra ? '1' : '0.3';
                el.style.pointerEvents = matchesEra ? 'auto' : 'none';
            });

            if (resultCount) resultCount.textContent = totalFound.toString();
            if (noResults) noResults.classList.toggle("hidden", totalFound > 0);
        }

        // --- Navigation Logic ---
        function updateActiveState(id: string) {
            const section = document.getElementById(id);
            if (!section) return;

            const idx = Array.from(phaseSections).indexOf(section) + 1;
            const title = section.querySelector('h2')?.textContent || "";

            if (activeIdx) activeIdx.textContent = idx.toString().padStart(2, '0');
            if (activeTitle) activeTitle.textContent = title;

            menuItems.forEach(item => {
                item.classList.toggle('active', (item as HTMLElement).dataset.phaseId === id);
            });
        }

        // Floating Nav visibility & Progress
        window.addEventListener('scroll', () => {
            const scrolled = window.scrollY;
            if (floatingExplorer) {
                floatingExplorer.classList.toggle('visible', scrolled > 600);
            }

            const winHeight = document.documentElement.scrollHeight - window.innerHeight;
            const progress = (scrolled / winHeight) * 100;
            if (scrollProgress) scrollProgress.style.width = `${progress}%`;
        });

        explorerToggle?.addEventListener('click', () => {
            explorerMenu?.classList.toggle('open');
        });

        // --- Event Listeners ---
        [...Array.from(phaseCards), ...Array.from(menuItems)].forEach(btn => {
            btn.addEventListener('click', () => {
                const id = (btn as HTMLElement).dataset.phaseId;
                const section = document.getElementById(id!);
                if (section) {
                    const offset = 120;
                    window.scrollTo({
                        top: section.getBoundingClientRect().top + window.pageYOffset - offset,
                        behavior: 'smooth'
                    });
                    explorerMenu?.classList.remove('open');
                }
            });
        });

        eraBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                eraBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                activeEra = (btn as HTMLElement).dataset.era || 'all';
                if (filterLabel) filterLabel.textContent = btn.textContent;
                applyFilters();
            });
        });

        milestoneToggle?.addEventListener('click', () => {
            showOnlyMilestones = !showOnlyMilestones;
            milestoneToggle.classList.toggle('active', showOnlyMilestones);
            applyFilters();
        });

        quickJump?.addEventListener('input', () => {
            const val = quickJump.value;
            if (val) {
                const item = document.querySelector(`.episode-item[data-id="${val}"]`);
                if (item) {
                   const offset = 200;
                   window.scrollTo({
                       top: (item as HTMLElement).getBoundingClientRect().top + window.pageYOffset - offset,
                       behavior: 'smooth'
                   });
                   item.classList.add('highlight-flash');
                   setTimeout(() => item.classList.remove('highlight-flash'), 2000);
                }
            }
        });

        searchInput?.addEventListener('input', applyFilters);

        const phaseObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) updateActiveState(entry.target.id);
            });
        }, { threshold: 0.1, rootMargin: "-20% 0px -60% 0px" });

        phaseSections.forEach(section => phaseObserver.observe(section));

        // --- Intersection Observer for Reveal ---
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("is-visible");
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.05 });

        document.querySelectorAll(".reveal-on-scroll").forEach(el => revealObserver.observe(el));
    });
</script>

<style>
    /* --- Layout --- */
    .hidden { display: none; }
    
    .page-header {
        position: relative;
        padding: 8rem 0 10rem;
        background: radial-gradient(circle at 50% 30%, rgba(72, 119, 146, 0.1), transparent 70%);
        overflow: hidden;
    }

    .header-bg-glow {
        position: absolute;
        top: -100px;
        left: 50%;
        transform: translateX(-50%);
        width: 1200px;
        height: 600px;
        background: radial-gradient(circle, rgba(72,119,146,0.15) 0%, transparent 70%);
        filter: blur(100px);
        z-index: -1;
    }

    h1 {
        font-size: clamp(3rem, 10vw, 5.5rem);
        font-weight: 950;
        line-height: 0.95;
        margin-bottom: 2rem;
        letter-spacing: -0.05em;
        color: var(--oxford-navy);
    }

    .header-content p {
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        color: var(--text-muted);
        max-width: 800px;
        margin: 0 auto;
        line-height: 1.5;
    }

    /* --- Dashboard Enhancements --- */
    .input-group {
        display: flex;
        gap: 1rem;
        width: 100%;
    }

    .search-box { flex-grow: 1; }

    .jump-box {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(0,0,0,0.03);
        padding: 0 1.25rem;
        border-radius: 16px;
        border: 1px solid transparent;
        transition: all 0.3s;
    }

    .jump-box:focus-within {
        background: white;
        border-color: var(--cerulean);
        box-shadow: 0 0 0 4px rgba(72,119,146,0.1);
    }

    .jump-label {
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--cerulean);
        opacity: 0.6;
    }

    .jump-box input {
        width: 45px;
        background: transparent;
        border: none;
        outline: none;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--oxford-navy);
        padding: 1rem 0;
        text-align: center;
    }

    /* --- Floating Explorer --- */
    .floating-explorer {
        position: fixed;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        z-index: 1000;
        width: auto;
        max-width: 90vw;
        transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        opacity: 0;
        pointer-events: none;
    }

    .floating-explorer.visible {
        transform: translateX(-50%) translateY(0);
        opacity: 1;
        pointer-events: auto;
    }

    .floating-content {
        background: rgba(26, 54, 94, 0.9);
        backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 0.75rem;
        box-shadow: 0 30px 60px rgba(0,0,0,0.4);
        position: relative;
    }

    .floating-toggle {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        background: transparent;
        border: none;
        padding: 0.5rem 1rem;
        cursor: pointer;
        width: 100%;
        text-align: left;
    }

    .floating-toggle .idx {
        font-size: 0.75rem;
        font-weight: 900;
        color: #4ade80;
        background: rgba(74, 222, 128, 0.1);
        padding: 0.25rem 0.5rem;
        border-radius: 6px;
    }

    .floating-toggle .title {
        font-size: 0.95rem;
        font-weight: 800;
        color: white;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 250px;
    }

    .floating-toggle svg {
        color: white;
        opacity: 0.5;
        transition: transform 0.3s;
    }

    .floating-progress-track {
        position: absolute;
        bottom: 0;
        left: 20px;
        right: 20px;
        height: 2px;
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
        overflow: hidden;
    }

    .floating-progress-fill {
        height: 100%;
        background: #4ade80;
        width: 0%;
        transition: width 0.3s;
    }

    /* --- Explorer Menu --- */
    .explorer-menu {
        position: absolute;
        bottom: 100%;
        left: 0;
        width: 100%;
        background: rgba(26, 54, 94, 0.95);
        backdrop-filter: blur(30px);
        border-radius: 20px;
        margin-bottom: 1rem;
        padding: 1rem;
        max-height: 400px;
        overflow-y: auto;
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
        display: none;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        border: 1px solid rgba(255,255,255,0.1);
    }

    .explorer-menu.open {
        display: block;
        opacity: 1;
        transform: translateY(0);
    }

    .menu-grid {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem 1rem;
        background: transparent;
        border: none;
        border-radius: 10px;
        color: rgba(255,255,255,0.6);
        cursor: pointer;
        text-align: left;
        transition: all 0.2s;
    }

    .menu-item:hover {
        background: rgba(255,255,255,0.1);
        color: white;
    }

    .menu-item.active {
        background: rgba(74, 222, 128, 0.1);
        color: #4ade80;
    }

    .menu-item .m-idx { font-size: 0.7rem; font-weight: 800; opacity: 0.5; }
    .menu-item .m-title { font-size: 0.9rem; font-weight: 700; }

    /* --- Highlights --- */
    .phase-card.has-results {
        border: 2px solid var(--cerulean);
        background: rgba(72,119,146,0.05);
        animation: glow-pulse 2s infinite;
    }

    @keyframes glow-pulse {
        0% { box-shadow: 0 0 0 0 rgba(72,119,146,0.2); }
        70% { box-shadow: 0 0 0 15px rgba(72,119,146,0); }
        100% { box-shadow: 0 0 0 0 rgba(72,119,146,0); }
    }

    .highlight-flash {
        animation: flash-border 2s;
    }

    @keyframes flash-border {
        0% { border-color: var(--cerulean); box-shadow: 0 0 0 0 var(--cerulean); }
        10%, 90% { border-color: #4ade80; box-shadow: 0 0 30px var(--cerulean); transform: scale(1.02); }
        100% { border-color: transparent; box-shadow: none; transform: scale(1); }
    }

    /* --- Journey Stream --- */
    .phase-section {
        margin-bottom: 20rem;
    }

    .grid-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .grid-header h3 {
        font-size: 1.5rem;
        font-weight: 900;
        letter-spacing: -0.02em;
    }

    .scroll-hint {
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--cerulean);
        opacity: 0.5;
    }

    .phase-grid {
        display: flex;
        gap: 1.25rem;
        overflow-x: auto;
        padding-bottom: 1.5rem;
        scrollbar-width: thin;
        scrollbar-color: var(--cerulean) transparent;
    }

    .phase-card {
        flex: 0 0 240px;
        position: relative;
        padding: 2.5rem 1.5rem 1.5rem;
        border-radius: 20px;
        border: none;
        background: white;
        text-align: left;
        cursor: pointer;
        overflow: hidden;
        box-shadow: 0 10px 20px -5px rgba(0,0,0,0.05);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .phase-card-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 6px;
        opacity: 0.8;
    }

    .phase-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.1);
    }

    .phase-idx {
        display: block;
        font-size: 0.7rem;
        font-weight: 900;
        color: var(--cerulean);
        margin-bottom: 0.5rem;
        opacity: 0.6;
    }

    .phase-card h4 {
        font-size: 1.1rem;
        line-height: 1.2;
        margin-bottom: 1rem;
        color: var(--oxford-navy);
    }

    .phase-meta {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
        background: rgba(0,0,0,0.03);
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
    }

    /* --- Journey Stream --- */
    .phase-section {
        margin-bottom: 12rem;
        position: relative;
    }

    .phase-bg-number {
        position: absolute;
        top: -6rem;
        left: -4rem;
        font-size: 20rem;
        font-weight: 1000;
        color: var(--oxford-navy);
        opacity: 0.015;
        line-height: 1;
        user-select: none;
        z-index: 0;
    }

    .phase-header {
        margin-bottom: 4rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        position: relative;
        z-index: 2;
    }

    .era-indicator {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--cerulean);
        margin-bottom: 1.5rem;
    }

    .phase-header h2 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 950;
        margin-bottom: 1rem;
        letter-spacing: -0.04em;
    }

    .phase-header p {
        font-size: 1.25rem;
        color: var(--text-muted);
        max-width: 750px;
        line-height: 1.6;
    }

    .grid-layout {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 3rem;
    }

    .episode-item.featured { grid-column: span 2; }

    /* --- Reveal --- */
    .reveal-on-scroll {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
    }

    .reveal-on-scroll.is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    @media (max-width: 1024px) {
        .grid-layout { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    }

    @media (max-width: 768px) {
        .page-header { padding: 4rem 1.5rem; text-align: left; }
        .filter-actions { flex-direction: column; align-items: stretch; }
        .grid-layout { grid-template-columns: 1fr; }
        .episode-item.featured { grid-column: span 1; }
