---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import YouTubeAudioPlayer from "../../components/YouTubeAudioPlayer.astro";
import { episodes } from "../../data/episodes";
import { getEntry } from "astro:content";
import { marked } from "marked";

export async function getStaticPaths() {
    return episodes.map((ep) => {
        const collectionSlug = `${ep.id}-${ep.slug}`;
        return {
            params: { slug: ep.slug },
            props: {
                episodeBasic: ep,
                collectionSlug,
            },
        };
    });
}

const { episodeBasic, collectionSlug } = Astro.props;

// Fetch the content collection entry
const entry = await getEntry("episodes", collectionSlug);

if (!entry) {
    throw new Error(`Episode content not found for slug: ${collectionSlug}`);
}

const { Content } = await entry.render();

// comments: Merge the markdown data with the basic episode info
const episode = {
    ...entry.data,
    ...episodeBasic,
    series: "Prophetic Biography",
    speaker: "Abdul Nasir Jangda",
};

const summaryHtml = await marked.parseInline(episode.summary || "");
---

<Layout
    title={`${episode.title} - Seerah Podcast`}
    description={episode.seoDescription}
    image={episode.image}
>
    <Navbar />

    <main class="episode-page">
        <header class="episode-hero">
            <div class="container container--narrow">
                <a href="/episodes" class="back-button">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="19" y1="12" x2="5" y2="12"></line><polyline
                            points="12 19 5 12 12 5"></polyline></svg
                    >
                    Back to Episodes
                </a>

                <h1
                    class="gradient-title"
                    transition:name={`episode-title-${episode.slug}`}
                >
                    {episode.title}
                </h1>

                <div class="meta-row">
                    <div class="meta-pill">
                        <span class="label">Series</span>
                        <span class="value">{episode.series}</span>
                    </div>
                    <div class="meta-pill">
                        <span class="label">Speaker</span>
                        <span class="value">{episode.speaker}</span>
                    </div>
                    <div class="meta-pill">
                        <span class="label">Duration</span>
                        <span class="value">{episode.duration}</span>
                    </div>
                    <div class="meta-pill">
                        <span class="label">Episode</span>
                        <span class="value">#{episode.id}</span>
                    </div>
                </div>

                <YouTubeAudioPlayer episode={episode} />

                <div class="action-bar">
                    <div class="share-actions">
                        <button
                            class="circle-action"
                            aria-label="Share on X"
                            onclick={`window.open('https://twitter.com/intent/tweet?url=' + encodeURIComponent(window.location.href) + '&text=' + encodeURIComponent('${episode.title} - Seerah Podcast'), '_blank')`}
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                stroke-width="2"
                                stroke="currentColor"
                                fill="none"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path
                                    stroke="none"
                                    d="M0 0h24v24H0z"
                                    fill="none"></path>
                                <path d="M4 4l11.733 16h4.267l-11.733 -16z"
                                ></path>
                                <path
                                    d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"
                                ></path>
                            </svg>
                        </button>
                        <button
                            class="circle-action"
                            title="Share on Facebook"
                            aria-label="Share on Facebook"
                            onclick={`window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(window.location.href), '_blank')`}
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path
                                    d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                                ></path>
                            </svg>
                        </button>
                        <button
                            class="circle-action"
                            title="Share on WhatsApp"
                            aria-label="Share on WhatsApp"
                            onclick={`window.open('https://api.whatsapp.com/send?text=' + encodeURIComponent('${episode.title} - Seerah Podcast ') + encodeURIComponent(window.location.href), '_blank')`}
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                            >
                                <g
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-linejoin="round"
                                    stroke-width="1"
                                >
                                    <path
                                        d="M17 16.5c-1.74 1.74-5.749.257-7.753-1.747S5.76 8.74 7.5 7c.504-.504 1.198-.564 1.622-.544c.245.011.457.155.6.355l.952 1.334a1 1 0 0 1-.107 1.288l-.901.901c.166.5.7 1.7 1.5 2.5s2 1.334 2.5 1.5l.901-.9a1 1 0 0 1 1.288-.108l1.334.952c.2.143.344.355.355.6c.02.424-.04 1.118-.544 1.622Z"
                                    ></path>
                                    <path
                                        d="M12 22.5c5.799 0 10.5-4.701 10.5-10.5S17.799 1.5 12 1.5S1.5 6.201 1.5 12c0 1.912.511 3.706 1.405 5.25l-.88 4.725l4.725-.88A10.45 10.45 0 0 0 12 22.5Z"
                                    ></path>
                                </g>
                            </svg>
                        </button>
                    </div>

                    <a
                        href={episode.link}
                        download
                        class="circle-action download-action"
                        title="Download Episode"
                        aria-label="Download Episode"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                            ></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </header>

        <article class="episode-article">
            <div class="container container--narrow">
                <!-- Section 1: Summary -->
                <section class="section-block">
                    <header class="blog-section-header">
                        <span class="section-category">Overview</span>
                        <h2 class="section-title-premium">Episode Summary</h2>
                    </header>
                    <div class="premium-content-box">
                        <p class="summary-text" set:html={summaryHtml} />
                    </div>
                </section>

                <!-- Section 2: Highlights -->
                {
                    episode.highlights && episode.highlights.length > 0 && (
                        <section class="section-block">
                            <header class="blog-section-header">
                                <span class="section-category">
                                    Key Takeaways
                                </span>
                                <h2 class="section-title-premium">
                                    Key Highlights
                                </h2>
                            </header>
                            <div class="premium-content-box">
                                <ul class="highlights-list-classic">
                                    {episode.highlights.map((point: string) => (
                                        <li>
                                            <span>{point}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </section>
                    )
                }

                <!-- Section 3: Deep Dive -->
                <section class="section-block">
                    <header class="blog-section-header">
                        <span class="section-category">Deep Dive</span>
                        <h2 class="section-title-premium">
                            Comprehensive Analysis
                        </h2>
                    </header>
                    <div class="content-prose-premium">
                        <Content />
                    </div>
                </section>
            </div>
        </article>
    </main>

    <Footer />
</Layout>

<style>
    .episode-page {
        background: #ffffff;
        color: var(--text-main);
    }

    .container--narrow {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* Hero Styling */
    .episode-hero {
        padding: 5.5rem 0 4.5rem;
        background: linear-gradient(
            165deg,
            var(--oxford-navy) 0%,
            #112240 100%
        );
        color: white;
        position: relative;
        overflow: hidden;
    }

    .episode-hero::after {
        content: "";
        position: absolute;
        top: -10%;
        right: -10%;
        width: 50%;
        height: 80%;
        /* background: radial-gradient(
            circle at center,
            rgba(72, 119, 146, 0.12),
            transparent 70%
        ); */
        pointer-events: none;
    }

    .back-button {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        color: white;
        font-weight: 700;
        margin-bottom: 2rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        backdrop-filter: blur(10px);
    }

    .back-button:hover {
        background: var(--cerulean);
        border-color: var(--cerulean);
        transform: translateY(-3px);
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.3);
    }

    .back-button svg {
        transition: transform 0.3s ease;
    }

    .back-button:hover svg {
        transform: translateX(-4px);
    }

    .gradient-title {
        font-size: clamp(2.5rem, 7vw, 4.2rem);
        line-height: 1.05;
        margin-bottom: 1.5rem;
        font-weight: 900;
        color: white;
        letter-spacing: -0.02em;
    }

    .meta-row {
        display: flex;
        gap: 2rem;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
    }

    .meta-pill {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
    }

    .meta-pill .label {
        font-size: 0.75rem;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.6);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .meta-pill .value {
        font-weight: 600;
        color: white;
        font-size: 1rem;
    }

    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .share-actions {
        display: flex;
        gap: 1.25rem;
    }

    .circle-action {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.8);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .circle-action:hover {
        border-color: var(--cerulean);
        color: white;
        background: var(--cerulean);
        transform: translateY(-3px);
    }

    /* Article Content */
    .episode-article {
        padding: 5rem 0 8rem;
    }

    /* Premium Blog Styling */
    .section-block {
        /* margin-bottom: 7rem; */
        margin-bottom: 4rem;
    }

    .blog-section-header {
        margin-bottom: 3.5rem;
        position: relative;
    }

    .section-category {
        display: block;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: var(--cerulean);
        margin-bottom: 0.75rem;
    }

    .section-title-premium {
        font-size: 2.5rem;
        font-weight: 900;
        color: var(--oxford-navy);
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .premium-content-box {
        background: rgba(72, 119, 146, 0.04);
        border-radius: var(--radius-md);
        padding: 3rem;
        border-left: 5px solid var(--cerulean);
        box-shadow: 0 4px 20px -5px rgba(0, 0, 0, 0.05);
    }

    .summary-text {
        font-size: 1.3rem;
        line-height: 1.7;
        color: #2d3748;
        font-weight: 500;
        margin: 0;
    }

    .highlights-list-classic {
        list-style: none;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .highlights-list-classic li {
        display: flex;
        gap: 1.25rem;
        font-size: 1.2rem;
        line-height: 1.6;
        color: #4a5568;
        align-items: flex-start;
    }

    .highlights-list-classic li::before {
        content: "•";
        color: var(--cerulean);
        font-weight: 900;
        font-size: 2rem;
        line-height: 0.8;
        margin-top: -0.1rem;
    }

    /* Advanced Prose Typography */
    .content-prose-premium {
        font-size: 1.25rem;
        line-height: 1.85;
        color: #2d3748;
    }

    .content-prose-premium :global(section) {
        margin-bottom: 4.5rem;
    }

    .content-prose-premium :global(section:last-child) {
        margin-bottom: 0;
    }

    .content-prose-premium :global(h3) {
        font-size: 1.85rem;
        font-weight: 800;
        color: var(--oxford-navy);
        margin-bottom: 1.5rem;
        letter-spacing: -0.015em;
        line-height: 1.2;
    }

    .content-prose-premium :global(p) {
        margin-bottom: 1.75rem;
    }

    .content-prose-premium :global(strong) {
        color: var(--oxford-navy);
        font-weight: 600;
    }

    .content-prose-premium :global(ul) {
        margin-bottom: 1.75rem;
        padding-left: 0;
        list-style: none;
    }

    .content-prose-premium :global(li) {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.75rem;
    }

    .content-prose-premium :global(li::before) {
        content: "";
        position: absolute;
        left: 0;
        top: 0.7em;
        width: 6px;
        height: 6px;
        background-color: var(--cerulean);
        border-radius: 50%;
    }

    .video-section {
        margin-top: 4rem;
    }

    .video-frame {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.2);
    }

    .video-frame iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    @media (max-width: 768px) {
        .episode-hero {
            /* padding: 4rem 1.5rem 3rem; */
            padding: 3rem 0rem;
        }

        .gradient-title {
            font-size: 2rem;
            margin-bottom: 1.25rem;
            letter-spacing: -0.01em;
        }

        .back-button {
            padding: 0.6rem 1rem;
            font-size: 0.7rem;
            margin-bottom: 1.5rem;
        }

        .meta-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem 1rem;
            margin-bottom: 2.5rem;
        }

        .meta-pill {
            flex-direction: column;
            gap: 0.1rem;
        }

        .meta-pill .label {
            font-size: 0.6rem;
            opacity: 0.7;
        }

        .meta-pill .value {
            font-size: 0.85rem;
            font-weight: 700;
        }

        .yt-audio-player {
            margin-bottom: 2rem;
        }

        .section-block {
            margin-bottom: 5rem;
        }

        .section-title-premium {
            font-size: 1.8rem;
        }

        .premium-content-box {
            padding: 2.25rem 1.75rem;
            border-radius: 12px;
        }

        .summary-text {
            font-size: 1.1rem;
        }

        .highlights-list-classic li {
            font-size: 1.05rem;
            gap: 1rem;
        }

        .content-prose-premium {
            font-size: 1.1rem;
        }

        .content-prose-premium :global(h4) {
            font-size: 1.5rem;
        }
    }
</style>
