---
import { Image } from "astro:assets";
import defaultThumb from "../assets/thumb.jpg";
import { MILESTONES } from "../data/phases";

interface Props {
    episode: {
        id: string | number;
        title: string;
        slug: string;
        description: string;
        duration: string;
        date: string;
        image: string;
    };
    featured?: boolean;
}

const { episode, featured = false } = Astro.props;

// Determine which image to use. If it's the default thumb path, use the optimized import.
const imageSrc = (
    episode.image === "/thumb.jpg" ? defaultThumb : episode.image
) as any;

const isMilestone = MILESTONES.includes(Number(episode.id));
---

<article class={`episode-card glass-card ${featured ? 'featured' : ''}`}>
    <div class="card-image">
        <Image
            src={imageSrc}
            alt={episode.title}
            width={400}
            height={225}
            loading="lazy"
            transition:name={`episode-image-${episode.slug}`}
        />
        <span class="duration">{episode.duration}</span>
        {isMilestone && <span class="milestone-badge">★ Milestone</span>}
    </div>
    <div class="card-content">
        <span class="date">{episode.date}</span>
        <h3 transition:name={`episode-title-${episode.slug}`}>
            <a href={`/episodes/${episode.slug}`}>{episode.title}</a>
        </h3>
        <p>{episode.description}</p>
        <div class="card-footer">
            <a href={`/episodes/${episode.slug}`} class="play-btn">
                <span class="icon">▶</span> Listen Now
            </a>
        </div>
    </div>
</article>

<style>
    .episode-card {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        height: 100%;
        position: relative;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    .episode-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg);
    }

    .episode-card {
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .episode-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 25px 50px -12px rgba(26, 54, 94, 0.15);
        border-color: rgba(72, 119, 146, 0.3);
        z-index: 10;
    }

    .episode-card.featured {
        background: linear-gradient(135deg, #ffffff, #f7fafc);
        box-shadow: 0 30px 60px -15px rgba(26, 54, 94, 0.1);
        border: 1px solid rgba(72, 119, 146, 0.15);
    }

    .episode-card.featured .card-image {
        aspect-ratio: 21/9;
    }

    .episode-card.featured h3 {
        font-size: 1.8rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.2;
    }

    .episode-card.featured .card-content {
        padding: 2.5rem;
    }

    .card-image {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .episode-card:hover .card-image img {
        transform: scale(1.05);
    }

    .duration {
        position: absolute;
        bottom: 0.5rem;
        right: 0.5rem;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 600;
        z-index: 2;
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .date {
        font-size: 0.85rem;
        color: var(--cerulean);
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        display: block;
    }

    h3 {
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
        line-height: 1.3;
    }

    h3 a::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 1;
    }

    h3 a:hover {
        color: var(--cerulean);
    }

    p {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        margin-top: auto;
    }

    .play-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--oxford-navy);
        font-weight: 700;
        font-size: 0.9rem;
        position: relative;
        z-index: 2;
    }

    .play-btn .icon {
        width: 28px;
        height: 28px;
        background: var(--oxford-navy);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 0.7rem;
        transition: background 0.2s;
    }

    .play-btn:hover .icon {
        background: var(--cerulean);
    }

    .milestone-badge {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        background: linear-gradient(135deg, #ffd700, #ffa500);
        color: #000;
        padding: 0.25rem 0.75rem;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        z-index: 2;
    }
</style>
