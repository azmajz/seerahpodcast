<div id="continue-listening-hero" class="hidden">
    <!-- Cinematic Banner populated by JS -->
</div>

<script>
    import { episodes } from "../data/episodes";

    document.addEventListener('astro:page-load', () => {
        const root = document.getElementById('continue-listening-hero');
        const lastPlayedId = localStorage.getItem('lastPlayedEpisode');

        if (lastPlayedId && root) {
            const episode = episodes.find(ep => ep.id === lastPlayedId);
            
            if (episode) {
                root.classList.remove('hidden');
                root.innerHTML = `
                    <section class="banner-hero reveal-on-scroll">
                        <div class="banner-blur" style="background-image: url('/thumb.jpg')"></div>
                        <div class="banner-overlay"></div>
                        
                        <div class="banner-content container">
                            <div class="banner-badge">
                                <span class="pulse"></span>
                                READY TO RESUME
                            </div>
                            
                            <div class="banner-main">
                                <div class="banner-text">
                                    <span class="ep-id">Episode ${episode.id}</span>
                                    <h2>${episode.title}</h2>
                                    <p>Continue where you left off in your journey through the Prophetic biography.</p>
                                </div>
                                
                                <div class="banner-actions">
                                    <a href="/episodes/${episode.slug}" class="play-btn-large">
                                        <div class="btn-icon">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                                        </div>
                                        <div class="btn-text">
                                            <span class="small">Resume Your Journey</span>
                                            <span class="large">Play Lesson</span>
                                        </div>
                                    </a>
                                    <button class="dismiss-icon" id="dismiss-hero" title="Dismiss">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                        
                        <div class="banner-progress">
                            <div class="progress-fill" style="width: 65%;"></div>
                        </div>
                    </section>
                `;

                document.getElementById('dismiss-hero')?.addEventListener('click', () => {
                    root.style.opacity = '0';
                    root.style.transform = 'scale(0.95)';
                    setTimeout(() => root.style.display = 'none', 400);
                });
            }
        }
    });
</script>

<style>
