---
export interface Props {
  episode: any;
}

const { episode } = Astro.props;
---

<div
  class="yt-audio-player"
  id="audio-player-root"
  data-image={episode.image || "/thumb.jpg"}
>
  <audio id="main-audio" src={episode.link} preload="metadata"></audio>

  <div class="yt-player-visuals" id="yt-visuals">
    <img
      src={episode.image || "/thumb.jpg"}
      alt={episode.title}
      transition:name={`episode-image-${episode.slug}`}
      class="yt-thumbnail-img"
    />
    <div class="yt-top-gradient"></div>
    <div class="yt-gradient-overlay"></div>

    <div class="yt-top-info">
      <div class="yt-title" id="yt-player-title">
        {episode.title}
      </div>
    </div>

    <div class="yt-center-play-alert" id="big-center-play">
      <svg viewBox="0 0 68 48">
        <path
          class="ytp-large-play-button-bg"
          d="M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55 C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19 C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z"
          fill="#212121"
          fill-opacity="0.8"></path>
        <path d="M 45,24 27,14 27,34" fill="#fff"></path>
      </svg>
    </div>

    <div class="yt-bottom-controls" id="yt-controls">
      <div class="yt-progress-container" id="progress-wrapper">
        <div class="yt-progress-bg">
          <div class="yt-progress-fill" id="progress-fill"></div>
        </div>
        <input
          type="range"
          id="seek-slider"
          min="0"
          value="0"
          step="0.1"
          aria-label="Seek audio"
        />
      </div>

      <div class="yt-controls-row">
        <button class="yt-control-btn" id="play-pause-btn" aria-label="Play">
          <svg class="play-icon" viewBox="0 0 36 36"
            ><path
              fill="currentColor"
              d="M 12,26 18.5,22 18.5,14 12,10 z M 18.5,22 25,18 25,18 18.5,14 z"
            ></path></svg
          >
          <svg class="pause-icon" viewBox="0 0 36 36" style="display: none;"
            ><path
              fill="currentColor"
              d="M 12,26 16,26 16,10 12,10 z M 21,26 25,26 25,10 21,10 z"
            ></path></svg
          >
        </button>

        <div class="yt-time-display">
          <span id="current-time">0:00</span>
          <span class="yt-time-separator">/</span>
          <span id="total-duration">{episode.duration}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .yt-audio-player {
    width: 100%;
    margin-bottom: 3.5rem;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .yt-player-visuals {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 ratio */
    background: #000;
    cursor: pointer;
  }

  .yt-thumbnail-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
    transition: opacity 0.3s;
  }

  .yt-player-visuals:hover .yt-thumbnail-img {
    opacity: 1;
  }

  .yt-gradient-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 60%;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    pointer-events: none;
  }

  .yt-top-gradient {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 40%;
    background: linear-gradient(rgba(0, 0, 0, 0.8), transparent);
    pointer-events: none;
  }

  .yt-top-info {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    padding: 1.5rem;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .yt-title {
    color: #fff;
    font-size: 1.35rem;
    font-weight: 500;
    text-shadow: 0 0 4px rgba(0, 0, 0, 0.8);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  }

  .yt-center-play-alert {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 68px;
    height: 48px;
    transition: opacity 0.2s;
  }

  .yt-player-visuals.playing .yt-center-play-alert {
    opacity: 0;
  }

  .ytp-large-play-button-bg {
    transition:
      fill 0.1s cubic-bezier(0.4, 0, 1, 1),
      fill-opacity 0.1s cubic-bezier(0.4, 0, 1, 1);
  }

  .yt-player-visuals:hover .ytp-large-play-button-bg {
    fill: #ff0000;
    fill-opacity: 1;
  }

  .yt-bottom-controls {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 0 1rem 0.5rem;
    display: flex;
    flex-direction: column;
    transition: opacity 0.3s;
  }

  .yt-player-visuals:not(:hover).playing .yt-bottom-controls,
  .yt-player-visuals:not(:hover).playing .yt-top-info {
    opacity: 0;
  }

  .yt-progress-container {
    position: relative;
    width: 100%;
    height: 5px;
    margin-bottom: 0.25rem;
    transition: height 0.1s;
  }

  .yt-progress-container:hover {
    height: 8px;
  }

  .yt-progress-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.2);
  }

  .yt-progress-fill {
    height: 100%;
    background: #ff0000;
    width: 0%;
    position: relative;
  }

  .yt-progress-container:hover .yt-progress-fill::after {
    content: "";
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-50%);
    width: 12px;
    height: 12px;
    background: #ff0000;
    border-radius: 50%;
  }

  #seek-slider {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    margin: 0;
  }

  .yt-controls-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .yt-control-btn {
    background: none;
    border: none;
    color: white;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.2s;
  }

  .yt-control-btn:hover {
    opacity: 0.8;
  }

  .yt-control-btn svg {
    width: 36px;
    height: 36px;
  }

  .yt-time-display {
    color: #fff;
    font-size: 0.85rem;
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    display: flex;
    gap: 0.5rem;
  }

  .yt-time-separator {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .yt-audio-player {
      margin-bottom: 3rem;
      border-radius: 8px;
    }
    .yt-title {
      font-size: 1.1rem;
    }
    .yt-controls-row {
      gap: 0.5rem;
    }
    .yt-time-display {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const audio = document.getElementById("main-audio") as HTMLAudioElement;
    const playPauseBtn = document.getElementById("play-pause-btn");
    const playIcon = playPauseBtn?.querySelector(".play-icon") as HTMLElement;
    const pauseIcon = playPauseBtn?.querySelector(".pause-icon") as HTMLElement;
    const progressFill = document.getElementById("progress-fill");
    const seekSlider = document.getElementById(
      "seek-slider",
    ) as HTMLInputElement;
    const currentTimeEl = document.getElementById("current-time");
    const ytVisuals = document.getElementById("yt-visuals");

    if (audio) {
      // Force reload source on View Transitions to avoid DOMException
      audio.load();
    }

    const formatTime = (seconds: number) => {
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${mins}:${secs.toString().padStart(2, "0")}`;
    };

    const togglePlay = async () => {
      if (!audio) return;
      if (audio.paused) {
        try {
          await audio.play();
          if (playIcon) playIcon.style.display = "none";
          if (pauseIcon) pauseIcon.style.display = "block";
          if (ytVisuals) ytVisuals.classList.add("playing");
        } catch (error) {
          console.error("Audio playback failed:", error);
          try {
            audio.load();
            await audio.play();
            if (playIcon) playIcon.style.display = "none";
            if (pauseIcon) pauseIcon.style.display = "block";
            if (ytVisuals) ytVisuals.classList.add("playing");
          } catch (retryError) {
            console.error("Retry playback failed:", retryError);
          }
        }
      } else {
        audio.pause();
        if (playIcon) playIcon.style.display = "block";
        if (pauseIcon) pauseIcon.style.display = "none";
        if (ytVisuals) ytVisuals.classList.remove("playing");
      }
    };

    if (ytVisuals) {
      ytVisuals.addEventListener("click", (e) => {
        // If the click is on the progress bar or controls, don't toggle play
        if ((e.target as HTMLElement).closest("#yt-controls")) return;
        togglePlay();
      });
    }

    if (playPauseBtn && audio) {
      // Set up Media Session API but avoid causing fallback thumbnail polling
      if ("mediaSession" in navigator) {
        const titleStr =
          document.getElementById("yt-player-title")?.textContent ||
          "Seerah Podcast";
        const rootEl = document.getElementById("audio-player-root");
        const imageSrc = rootEl?.dataset.image;

        let artwork: any[] = [];
        if (imageSrc) {
          try {
            const absUrl = new URL(imageSrc, window.location.origin).href;
            // Avoid using fallback thumb.jpg to prevent continuous loading polling issues
            if (!absUrl.includes("thumb.jpg")) {
              artwork = [
                {
                  src: absUrl,
                  sizes: "512x512",
                  type: "image/jpeg",
                },
              ];
            }
          } catch (e) {
            // ignore invalid url
          }
        }

        navigator.mediaSession.metadata = new MediaMetadata({
          title: titleStr,
          artist: "Abdul Nasir Jangda",
          album: "Prophetic Biography",
          artwork: artwork,
        });

        navigator.mediaSession.setActionHandler("play", togglePlay);
        navigator.mediaSession.setActionHandler("pause", togglePlay);
        navigator.mediaSession.setActionHandler("seekto", (details) => {
          if (details.seekTime !== undefined) {
            audio.currentTime = details.seekTime;
          }
        });
      }

      playPauseBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        togglePlay();
      });

      audio.addEventListener("timeupdate", () => {
        const progress = (audio.currentTime / audio.duration) * 100;
        if (progressFill) progressFill.style.width = `${progress}%`;
        if (seekSlider) seekSlider.value = audio.currentTime.toString();
        if (currentTimeEl)
          currentTimeEl.textContent = formatTime(audio.currentTime);
      });

      audio.addEventListener("loadedmetadata", () => {
        if (seekSlider) seekSlider.max = audio.duration.toString();
        // duration is already hydrated via SSR but we could update it
      });

      seekSlider?.addEventListener("input", (e) => {
        e.stopPropagation();
        audio.currentTime = parseFloat(seekSlider.value);
        if (currentTimeEl)
          currentTimeEl.textContent = formatTime(audio.currentTime);
      });
      seekSlider?.addEventListener("click", (e) => e.stopPropagation());
    }
  });
</script>
